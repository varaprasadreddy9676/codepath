# CodePath Intelligence Engine Environmental Config

# 1. The Target Application configuration
# Point this to whatever external application you want the Engine to diagnose
TARGET_APP_DB_URL=postgresql://readonly_user:password@localhost/customer_target_db

# 2. Engine Internal Subsystems
QDRANT_URL=http://localhost:6333
NEO4J_URL=bolt://localhost:7687
JAEGER_URL=http://localhost:16686

# 3. External Intelligence Inference (The Brain)
# By default, uses OpenAI. Change URL to http://localhost:11434/v1/chat/completions for Ollama/vLLM.
OPENAI_API_KEY=your_openai_api_key_here
LLM_API_URL=https://api.openai.com/v1/chat/completions
